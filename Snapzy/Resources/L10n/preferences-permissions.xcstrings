{
  "sourceLanguage": "en",
  "strings": {
    "preferences-permissions.intro": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy benötigt bestimmte Berechtigungen, um Ihren Bildschirm und Audio aufzunehmen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy requires certain permissions to capture your screen and audio."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy requiere ciertos permisos para capturar su pantalla y audio."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy nécessite certaines autorisations pour capturer votre écran et votre audio."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy が画面と音声をキャプチャするには、いくつかの権限が必要です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy가 화면과 오디오를 캡처하려면 특정 권한이 필요합니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy требует определенных разрешений для захвата экрана и звука."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy cần một số quyền để chụp màn hình và ghi âm."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy 需要特定权限才能捕获您的屏幕和音频。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy 需要特定權限才能捕獲您的螢幕和音頻。"
          }
        }
      }
    }
  },
  "version": "1.0"
}
