// Secrets.xcconfig.example
// Copy this file to Secrets.xcconfig and fill in the values.
// Secrets.xcconfig is git-ignored and will NOT be committed.

POLAR_ORG_ID = your-org-id-here
POLAR_API_BASE_URL = https:/$()/api.polar.sh/v1/customer-portal
POLAR_SANDBOX_API_BASE_URL = https:/$()/sandbox-api.polar.sh/v1/customer-portal
